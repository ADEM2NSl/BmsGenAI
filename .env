# ============================================================
# BMS GenAI Assistant — Environment Configuration
# Copy this file to .env and adjust values
# ============================================================

# --- App ---
APP_NAME=BMS GenAI Assistant
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=bms-secret-key-change-in-production-2024

# --- Paths ---
DATA_DIR=./data
OUTPUTS_DIR=./outputs
UPLOADS_DIR=./data/uploads
DB_PATH=./data/bms.db
CHROMA_PATH=./data/chroma_db

# --- LLM (Ollama — local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_TIMEOUT=120

# --- spaCy Models ---
SPACY_MODEL_DE=de_core_news_sm
SPACY_MODEL_EN=en_core_web_sm

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Auth ---
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Notifications ---
NOTIFY_EMAIL=engineer@company.com
TEAMS_WEBHOOK_URL=

# --- CI/CD ---
GITLAB_TOKEN=
PIPELINE_TRIGGER_DIR=./data/uploads
